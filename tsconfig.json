{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"jsx": "react-jsx",
		"strict": true,
		"moduleResolution": "node",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"baseUrl": "./"
	},
	"include": ["src/**/*", "**/*.ts", "**/*.tsx"],
	"exclude": ["node_modules", "dist"]
}
